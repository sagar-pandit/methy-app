# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files to always use LF
*.cs        text eol=lf
*.csproj    text eol=lf
*.slnx      text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.xml       text eol=lf
*.config    text eol=lf
*.ps1       text eol=lf
Dockerfile  text eol=lf
.dockerignore text eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.zip       binary
*.gz        binary
