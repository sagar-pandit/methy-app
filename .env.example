# ============================================================
# Methy Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# SQL Server
# SA password must meet SQL Server complexity requirements:
# min 8 chars, uppercase, lowercase, digit, special char
SA_PASSWORD=YourStrong!Passw0rd

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Per-service connection strings (used in appsettings.json)
GATEWAY_CONNECTION_STRING=Server=localhost,1433;Database=methy;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true
USER_SERVICE_CONNECTION_STRING=Server=localhost,1433;Database=methy;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true
RESTAURANT_SERVICE_CONNECTION_STRING=Server=localhost,1433;Database=methy;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true
ORDER_SERVICE_CONNECTION_STRING=Server=localhost,1433;Database=methy;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true
PAYMENT_SERVICE_CONNECTION_STRING=Server=localhost,1433;Database=methy;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true
NOTIFICATION_SERVICE_CONNECTION_STRING=Server=localhost,1433;Database=methy;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true
DELIVERY_SERVICE_CONNECTION_STRING=Server=localhost,1433;Database=methy;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true

# RabbitMQ AMQP endpoint
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
