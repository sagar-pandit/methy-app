{
  "info": {
    "_postman_id": "methy-order",
    "name": "Methy - Order Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{orderServiceUrl}}/health",
          "host": ["{{orderServiceUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"restaurantId\": \"{{restaurantId}}\",\n  \"items\": [\n    { \"menuItemId\": \"{{menuItemId}}\", \"quantity\": 1 }\n  ]\n}"
        },
        "url": {
          "raw": "{{orderServiceUrl}}/api/orders",
          "host": ["{{orderServiceUrl}}"],
          "path": ["api", "orders"]
        }
      }
    }
  ]
}
