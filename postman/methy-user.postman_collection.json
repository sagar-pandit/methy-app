{
  "info": {
    "_postman_id": "methy-user",
    "name": "Methy - User Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{userServiceUrl}}/health",
          "host": ["{{userServiceUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Test User\"\n}"
        },
        "url": {
          "raw": "{{userServiceUrl}}/api/users/register",
          "host": ["{{userServiceUrl}}"],
          "path": ["api", "users", "register"]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "{{userServiceUrl}}/api/users/login",
          "host": ["{{userServiceUrl}}"],
          "path": ["api", "users", "login"]
        }
      }
    }
  ]
}
